# Job Hunter Environment Configuration
# Copy this file to .env and fill in your values
# You only need ONE AI provider key. The script auto-detects which one is present.

# ========== AI PROVIDER KEYS (choose ONE) ==========

# Claude (Anthropic)
# Get key at: https://console.anthropic.com/account/keys
# Free tier: 5 API calls/min, no credit limit (pay-as-you-go after trial)
ANTHROPIC_API_KEY=

# Gemini (Google)
# Get key at: https://aistudio.google.com/app/apikey
# Free tier: 60 requests/min, unlimited requests
GEMINI_API_KEY=

# Groq (fastest open-source inference)
# Get key at: https://console.groq.com/keys
# Free tier: unlimited requests (tokens-per-minute limits apply)
GROQ_API_KEY=

# DeepSeek (affordable reasoning model)
# Get key at: https://platform.deepseek.com/account/keys
# Free tier: $5 credit on signup
DEEPSEEK_API_KEY=

# Nvidia NIM (self-hosted inference)
# Get key at: https://build.nvidia.com/nvidia/nim/api
# Free tier: 1000 requests/day for select models
NVIDIA_API_KEY=

# ========== OPTIONAL: EMAIL NOTIFICATIONS ==========

# SendGrid API key for email notifications
# Get key at: https://app.sendgrid.com/settings/api_keys
# Leave empty to skip email notifications
SENDGRID_API_KEY=

# Your email address to receive job hunt notifications
# Leave empty to skip email notifications
NOTIFY_EMAIL=

# ========== LOGGING ==========

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
