# --- AI PROVIDERS ---
# You only need ONE of these. The script auto-detects which key is present.
# Priority: Anthropic > Gemini > Groq > DeepSeek > Nvidia

# Get Claude key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Get Gemini key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Get Groq key at: https://console.groq.com
GROQ_API_KEY=

# Get DeepSeek key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Get Nvidia NIM key at: https://build.nvidia.com
NVIDIA_API_KEY=

# Optional: special input value that tells the script to use the provider key
# from GitHub Actions secrets instead of treating the input as a real API key.
API_KEY_SECRET_SENTINEL=8642

# --- NOTIFICATIONS (Optional) ---
# Used to send an HTML summary of results to your email.
SENDGRID_API_KEY=
NOTIFY_EMAIL=
